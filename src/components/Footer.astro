---
import { getT } from '../lib/i18n';
import type { Lang } from '../lib/i18n';

type Props = { lang: Lang };
const { lang } = Astro.props as Props;

const t = getT(lang);
const href = (path: string) => `/${lang}${path}`;
const year: number = new Date().getFullYear();
---

<footer class="bg-white border-t border-[#E4E6E8] pt-16 pb-24 md:pb-16">
  <div class="max-w-[1120px] mx-auto px-4 md:px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="col-span-1 md:col-span-2">
        {/* Logo Group Consistent with Navbar */}
        <a href={href('/')} class="flex items-center gap-2.5 group mb-6 inline-flex">
          <div class="w-9 h-9 bg-[#C4161C] rounded-xl flex items-center justify-center transition-transform group-hover:scale-105 shadow-sm">
            <span class="text-white font-bold text-lg">K</span>
          </div>
          <div class="flex flex-col leading-none">
            <span class="text-xl font-bold tracking-tighter text-[#111111]">KUSI</span>
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#C4161C]">Fútbol Tours</span>
          </div>
        </a>

        <p class="text-[#111111]/60 leading-relaxed max-w-sm">
          {t.footer.description}
        </p>
      </div>

      <div>
        <h4 class="font-bold mb-4">{t.footer.company}</h4>
        <ul class="space-y-2 text-[#111111]/70">
          <li><a href={href('/experience')} class="hover:text-[#C4161C] transition-colors">{t.nav.experience}</a></li>
          <li><a href={href('/faq')} class="hover:text-[#C4161C] transition-colors">{t.nav.faq}</a></li>
          <li><a href={href('/hotels')} class="hover:text-[#C4161C] transition-colors">{t.nav.hostels}</a></li>
          <li><a href={href('/contact')} class="hover:text-[#C4161C] transition-colors">{t.footer.contact}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold mb-4">{t.footer.legal}</h4>
        <ul class="space-y-2 text-[#111111]/70">
          <li><a href={href('/terms')} class="hover:text-[#C4161C] transition-colors">{t.footer.terms}</a></li>
          <li><a href={href('/privacy')} class="hover:text-[#C4161C] transition-colors">{t.footer.privacy}</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[#E4E6E8] pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-[#111111]/40">
        © {year} KUSI Fútbol Tours. {t.footer.rights}
      </p>

      <div class="flex gap-6 grayscale opacity-20">
        {/* Placeholder for social icons */}
        <div class="w-5 h-5 bg-black rounded-sm"></div>
        <div class="w-5 h-5 bg-black rounded-full"></div>
      </div>
    </div>
  </div>
</footer>