---
---

<section
  id="hero"
  class="relative pt-16 pb-24 md:pt-24 md:pb-32 px-4 overflow-hidden"
>
  <div class="max-w-[1120px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

    <!-- Texto -->
    <div class="z-10">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] mb-6 tracking-tight">
        Live the real Peruvian football experience
      </h1>

      <p class="text-lg leading-relaxed mb-8">
        Safe. Authentic. Unforgettable.
      </p>

      <div class="flex gap-4">
        <button
          class="inline-flex items-center justify-center font-semibold transition-all active:scale-95 rounded-[14px] bg-[#C4161C] text-white hover:brightness-95 h-[44px] md:h-[48px] px-6 shadow-sm"
        >
          Book Now
        </button>

        <button
          class="inline-flex items-center justify-center font-semibold transition-all active:scale-95 rounded-[14px] bg-white text-[#111111] border border-[#E4E6E8] hover:bg-[#F7F8FA] h-[44px] md:h-[48px] px-6"
        >
          Learn More
        </button>
      </div>
    </div>

    <!-- Imagen Placeholder -->
    <div class="relative">
      <div class="aspect-[4/5] rounded-[24px] overflow-hidden shadow-2xl bg-[#E4E6E8] border-4 border-white relative flex items-center justify-center">
        <span class="text-sm text-gray-500">Hero Image Placeholder</span>
      </div>
    </div>

  </div>
</section>