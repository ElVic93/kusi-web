---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { getT } from "../../../lib/i18n";

const lang = "es";
const t = getT(lang);

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const esPosts = posts.filter((p) => p.data.lang === "es");

  return esPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await post.render();

// canonical absoluto (tu dominio inicial)
const SITE = "https://kusi-futbol-tour.vercel.app";
const canonical = post.data.canonical ?? `${SITE}/es/blog/${post.slug}/`;
---

<BaseLayout
  lang={lang}
  title={`${post.data.title} | KUSI`}
  description={post.data.description}
  canonical={canonical}
>
  <article class="py-16 md:py-24 px-4 bg-white">
    <div class="max-w-[800px] mx-auto">
      <header class="mb-10">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">{post.data.title}</h1>
        <p class="text-[#111111]/60 text-lg leading-relaxed">{post.data.description}</p>

        <div class="mt-6 text-sm text-[#111111]/40">
          {post.data.date.toISOString().slice(0, 10)}
        </div>

        {post.data.coverImage && (
          <img
            src={post.data.coverImage}
            alt={post.data.title}
            class="w-full h-[420px] object-cover rounded-[24px] border border-[#E4E6E8] mt-8"
            loading="lazy"
          />
        )}
      </header>

      <div class="prose prose-slate max-w-none">
        <Content />
      </div>

      <div class="mt-16 border-t border-[#E4E6E8] pt-10">
        <a
          href="/es/blog/"
          class="inline-flex items-center justify-center font-semibold rounded-[14px] bg-white border border-[#E4E6E8] hover:bg-[#F7F8FA] h-[44px] px-6"
        >
          {t.blogPage.backToBlog ?? "Volver al blog"}
        </a>
      </div>
    </div>
  </article>
</BaseLayout>