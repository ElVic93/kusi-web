---
import BaseLayout from '../../layouts/BaseLayout.astro';

import Button from '../../components/Button';

import { getWhatsAppLink } from '../../lib/utils';
import { getT } from '../../lib/i18n';

const lang = 'es';
const t = getT(lang);
---

<BaseLayout lang={lang} title={t.hostelsPage.title} description="">
  <div class="py-16 md:py-24 px-4 bg-white">
    <div class="max-w-[900px] mx-auto">

      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          {t.hostelsPage.title}
        </h1>
        <p class="text-xl text-[#111111]/60 leading-relaxed max-w-2xl mx-auto">
          {t.hostelsPage.subtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-20">
        
        <div>
          <p class="text-lg text-[#111111]/70 mb-8 leading-relaxed">
            {t.hostelsPage.description}
          </p>

          <h3 class="text-2xl font-bold mb-6">
            {t.hostelsPage.benefitsTitle}
          </h3>

          <ul class="space-y-4">
            {t.hostelsPage.benefits.map((benefit: string, i: number) => (
              <li class="flex gap-4 items-center">
                <div class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-sm flex-shrink-0">
                  ✓
                </div>
                <span class="text-[#111111]/80">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-[#F7F8FA] rounded-[32px] p-8">
          <img
            src="https://picsum.photos/600/400?grayscale&random=hotel"
            class="rounded-[20px] shadow-lg mb-8"
            alt="Hotel partner"
            loading="lazy"
          />

          <Button
            href={getWhatsAppLink(lang)}
            trackingLabel="Hotel Partner CTA"
            trackingSection="HotelsPage"
            fullWidth
            variant="primary"
            className="h-[56px] text-lg"
          >
            {t.hostelsPage.cta}
          </Button>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>