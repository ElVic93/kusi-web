---
import BaseLayout from '../../layouts/BaseLayout.astro';

import FAQAccordion from '../../components/FAQAccordion';
import Button from '../../components/Button';

import { getWhatsAppLink } from '../../lib/utils';
import { getT } from '../../lib/i18n';

const lang = 'en';
const t = getT(lang);
---

<BaseLayout lang={lang} title={t.faqPage.title} description="">
  <div class="py-16 md:py-24 px-4">
    <div class="max-w-[800px] mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight text-center">
        {t.faqPage.title}
      </h1>
      <p class="text-[#111111]/60 text-center mb-16 text-lg">
        {t.faqPage.subtitle}
      </p>

      <FAQAccordion client:visible items={t.faqPage.items} />

      <div class="mt-20 p-8 bg-[#F7F8FA] rounded-[24px] text-center border border-[#E4E6E8]">
        <h3 class="text-xl font-bold mb-4">{t.faqPage.moreQuestions}</h3>
        <p class="text-[#111111]/60 mb-8">{t.faqPage.supportText}</p>

        <Button
          href={getWhatsAppLink(lang)}
          trackingLabel="FAQ Help"
          trackingSection="FAQPage"
          variant="primary"
          className="px-12"
        >
          {t.faqPage.cta}
        </Button>
      </div>
    </div>
  </div>
</BaseLayout>