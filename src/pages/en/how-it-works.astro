---
import BaseLayout from '../../layouts/BaseLayout.astro';

import Card from '../../components/Card';
import Button from '../../components/Button';

import { getWhatsAppLink } from '../../lib/utils';
import { getT } from '../../lib/i18n';

const lang = 'en';
const t = getT(lang);
---

<BaseLayout lang={lang} title={t.howItWorksPage.title} description="">
  <div class="py-16 md:py-24 px-4 bg-white">
    <div class="max-w-[900px] mx-auto text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight">
        {t.howItWorksPage.title}
      </h1>
      <p class="text-xl text-[#111111]/60 leading-relaxed">
        {t.howItWorksPage.subtitle}
      </p>
    </div>

    <div class="max-w-[800px] mx-auto space-y-12">
      {t.howItWorksPage.steps.map((s: { icon: string; title: string; desc: string }, i: number) => (
        <div class="flex flex-col md:flex-row gap-8 items-start relative">
          {i !== t.howItWorksPage.steps.length - 1 && (
            <div class="hidden md:block absolute left-[27px] top-[60px] bottom-[-48px] w-[2px] bg-[#E4E6E8]"></div>
          )}

          <div class="w-14 h-14 rounded-2xl bg-[#C4161C] text-white flex items-center justify-center font-bold text-xl flex-shrink-0 z-10 shadow-lg shadow-[#C4161C]/20">
            {`0${i + 1}`}
          </div>

          <div class="pt-2">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="text-2xl font-bold mb-4">{s.title}</h3>
            <p class="text-lg text-[#111111]/70 leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="max-w-[800px] mx-auto mt-24">
      <Card className="bg-[#F7F8FA] border-none text-center py-12">
        <h2 class="text-2xl font-bold mb-6">{t.howItWorksPage.ctaTitle}</h2>

        <Button
          href={getWhatsAppLink(lang)}
          trackingLabel="HowItWorks Final CTA"
          trackingSection="HowItWorks"
          variant="primary"
          className="px-12 h-[56px] text-lg"
        >
          {t.howItWorksPage.ctaButton}
        </Button>
      </Card>
    </div>
  </div>
</BaseLayout>